    {
      "name": "5. Download as CSV",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is CSV file', function () {",
              "    var contentType = pm.response.headers.get('content-type');",
              "    pm.expect(contentType).to.include('text/csv');",
              "});",
              "",
              "pm.test('Response contains test case data', function () {",
              "    var responseText = pm.response.text();",
              "    pm.expect(responseText).to.include('test_id');",
              "    pm.expect(responseText).to.include('title');",
              "    pm.expect(responseText).to.include('type');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"format\": \"csv\",\n  \"test_cases\": [\n    {\n      \"test_case_id\": \"TC001\",\n      \"test_case_title\": \"Valid login with correct credentials\",\n      \"test_type\": \"Functional\",\n      \"priority\": \"High\",\n      \"preconditions\": [\"User account exists\", \"User is on login page\"],\n      \"test_steps\": [\"Navigate to login page\", \"Enter email\", \"Enter password\", \"Click login\"],\n      \"test_data\": [\"email: user@example.com\", \"password: ValidPass123\"],\n      \"expected_result\": \"User is logged in and redirected to dashboard\",\n      \"confidence_score\": 0.95,\n      \"review_status\": \"Approved\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/testcases/download",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "testcases",
            "download"
          ]
        },
        "description": "Export test cases as CSV file.\n\n**Request Body:**\n- `test_cases`: Array of test case objects to export\n- `format`: Export format ('csv' or 'json')"
      },
      "response": []
    },
