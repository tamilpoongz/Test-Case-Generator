        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Search Products\",\n  \"description\": \"Customer can search for products by keyword or category and filter results\",\n  \"acceptance_criteria\": [\n    \"Search returns matching products\",\n    \"Filter by category works correctly\"\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/testcases/generate",
          "host": [
            "{{base_url}}"
